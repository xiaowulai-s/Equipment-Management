<Window x:Class="EquipmentManagement.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EquipmentManagement"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        xmlns:prism="http://prismlibrary.com/"
        prism:ViewModelLocator.AutoWireViewModel="True"
        mc:Ignorable="d"
        Title="设备管理系统" Height="900" Width="1600" Background="#1E1E1E">
    <Window.Resources>
        <!-- 自定义样式 -->
        <Style TargetType="Button" x:Key="DeviceButtonStyle">
            <Setter Property="Background" Value="#2D2D2D" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Height" Value="50" />
            <Setter Property="Margin" Value="5" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="15" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3D3D3D" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#4D4D4D" />
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#00AAFF" />
                                <Setter TargetName="border" Property="BorderThickness" Value="2" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Border" x:Key="PanelStyle">
            <Setter Property="Background" Value="#2D2D2D" />
            <Setter Property="BorderBrush" Value="#3D3D3D" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Margin" Value="8" />
            <Setter Property="Padding" Value="15" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="5" ShadowDepth="2" Opacity="0.2" Color="Black" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBlock" x:Key="TitleTextStyle">
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="5 0 0 10" />
        </Style>

        <Style TargetType="TextBlock" x:Key="ValueTextStyle">
            <Setter Property="Foreground" Value="#00FFAA" />
            <Setter Property="FontSize" Value="24" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Margin" Value="5" />
        </Style>
    </Window.Resources>

    <Grid>
        <!-- 顶部导航栏 -->
        <Grid.RowDefinitions>
            <RowDefinition Height="60" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderBrush="#3D3D3D" BorderThickness="0 0 0 1">
            <DockPanel Background="#1E1E1E">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" Margin="10">
                    <Button Content="☰" Width="40" Height="40" Background="Transparent" Foreground="White" BorderThickness="0" />
                    <TextBlock Text="⛽" FontSize="20" Margin="10 0" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding Title}" FontSize="18" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" Margin="5" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" Margin="10">
                    <Button Content="👤" Width="40" Height="40" Background="Transparent" Foreground="White" BorderThickness="0" ToolTip="用户" />
                    <Button Content="📊" Width="40" Height="40" Background="Transparent" Foreground="White" BorderThickness="0" ToolTip="数据" />
                    <Button Content="🔔" Width="40" Height="40" Background="Transparent" Foreground="White" BorderThickness="0" ToolTip="通知" />
                    <Button Content="⚙️" Width="40" Height="40" Background="Transparent" Foreground="White" BorderThickness="0" ToolTip="设置" />
                    <Button Content="📋" Width="40" Height="40" Background="Transparent" Foreground="White" BorderThickness="0" ToolTip="菜单" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- 主内容区 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- 左侧设备列表 -->
            <Border Grid.Column="0" Style="{StaticResource PanelStyle}">
                <StackPanel>
                    <TextBlock Text="设备列表" Style="{StaticResource TitleTextStyle}" />
                    <ListBox ItemsSource="{Binding Devices}" 
                             SelectedItem="{Binding SelectedDevice}" 
                             Background="Transparent" 
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Button Style="{StaticResource DeviceButtonStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Icon}" FontSize="20" Margin="5" />
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>

            <!-- 右侧主内容区 -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="200" />
                <RowDefinition Height="300" />
            </Grid.RowDefinitions>

                <!-- 仪表盘和数据卡片 -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="300" />
                    </Grid.ColumnDefinitions>

                    <!-- 仪表盘 -->
                    <Border Grid.Column="0" Style="{StaticResource PanelStyle}">
                        <StackPanel>
                            <TextBlock Text="仪表盘" Style="{StaticResource TitleTextStyle}" />
                            <UniformGrid Columns="4" Margin="5">
                                <ItemsControl ItemsSource="{Binding Gauges}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel>
                                                <Border Background="#3D3D3D" CornerRadius="50" Height="80" Width="80" Margin="10" VerticalAlignment="Center">
                                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Value}" Foreground="#00FFAA" FontSize="16" FontWeight="Bold" />
                                                        <TextBlock Text="{Binding Name}" Foreground="White" FontSize="12" />
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </UniformGrid>
                        </StackPanel>
                    </Border>

                    <!-- 数据卡片 -->
                    <Border Grid.Column="1" Style="{StaticResource PanelStyle}">
                        <StackPanel>
                            <TextBlock Text="关键数据" Style="{StaticResource TitleTextStyle}" />
                            <ItemsControl ItemsSource="{Binding DataCards}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#3D3D3D" CornerRadius="5" Margin="5" Padding="10">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" Foreground="White" FontSize="12" />
                                                <TextBlock Text="{Binding Value}" Foreground="#00FFAA" FontSize="24" FontWeight="Bold" Margin="0 5" />
                                                <ProgressBar Value="{Binding Progress}" Height="5" Background="#4D4D4D" BorderThickness="0" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Modbus寄存器表格 -->
                <Border Grid.Row="1" Style="{StaticResource PanelStyle}">
                    <StackPanel>
                        <TextBlock Text="Modbus寄存器" Style="{StaticResource TitleTextStyle}" />
                        <DataGrid ItemsSource="{Binding Registers}" 
                                  Background="Transparent" 
                                  BorderThickness="0" 
                                  RowBackground="#3D3D3D" 
                                  AlternatingRowBackground="#2D2D2D"
                                  ColumnHeaderHeight="30"
                                  RowHeight="35"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  CanUserReorderColumns="False"
                                  CanUserResizeColumns="False"
                                  CanUserSortColumns="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Address" Binding="{Binding Address}" Width="*" Foreground="White" />
                                <DataGridTextColumn Header="Valate" Binding="{Binding Valate}" Width="*" Foreground="White" />
                                <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="*" Foreground="White" />
                                <DataGridTemplateColumn Header="Status" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="{Binding StatusColor}" 
                                                    CornerRadius="3" 
                                                    Padding="5 2" 
                                                    HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding StatusText}" 
                                                           Foreground="Black" 
                                                           FontWeight="Bold" 
                                                           FontSize="10" />
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#2D2D2D" />
                                    <Setter Property="Foreground" Value="#FFFFFF" />
                                    <Setter Property="BorderThickness" Value="0 0 1 1" />
                                    <Setter Property="BorderBrush" Value="#3D3D3D" />
                                    <Setter Property="Padding" Value="10" />
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="BorderThickness" Value="0 0 0 1" />
                                    <Setter Property="BorderBrush" Value="#3D3D3D" />
                                </Style>
                            </DataGrid.RowStyle>
                        </DataGrid>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
