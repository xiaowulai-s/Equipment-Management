# ═══════════════════════════════════════════════════════════
# 工业设备管理系统 - Flake8代码检查配置
# ═══════════════════════════════════════════════════════════

[flake8]
# 最大行长度 (与Black对齐)
max-line-length = 100

# 排除目录
exclude =
    .git,
    __pycache__,
    venv,
    build,
    dist,
    .eggs,
    *.egg-info,
    htmlcov

# 错误码忽略:
#   E501: 行长度由Black处理
#   W503: 运算符前换行 (Black会处理)
#   E203: 切片前的空格 (与Black冲突)
#   C901: 函数复杂度 (在PR中人工审查)
ignore = E501, W503, E203, C901

# 每文件最大复杂度警告
max-complexity = 15

# 统计
statistics = True
count = True

# 类型注解检查 (通过pep8-naming)
# import-nameStyle: 类名使用CamelCase
# function-nameStyle: 函数名使用snake_case
